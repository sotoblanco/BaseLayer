# Gemini API Key for AI Service
GEMINI_API_KEY=your_gemini_api_key_here

# JWT Secret Key for Authentication
SECRET_KEY=super-secret-key-change-me-in-production

# Database configuration (defaults to sqlite:///database.db)
# DATABASE_URL=sqlite:///database.db

# Backend configuration
# Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Test configuration
# The base URL for the API during tests
BASE_URL=http://localhost:8000

# Optional: Directory for course content (defaults to ./courses)
# COURSES_DIR=/absolute/path/to/courses

# Modal Deployment Settings (Optional)
MODAL_APP_NAME=code-app
MODAL_VOLUME_NAME=code-app-volume
MODAL_SECRET_NAME=code-app-secrets

# Google Sheets Integration (Optional)
# GOOGLE_SERVICE_ACCOUNT_FILE=path/to/service-account.json
